# ─────────────────────────────────────────────────────────────────────────────
# Plink backend — environment template
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=8080

# Database
DATABASE_URL="postgresql://user:pass@host:port/dbname"

# Redis (required for multi-replica realtime state — see Stage 3)
REDIS_URL="redis://localhost:6379"

# JWT
# MUST be >=32 chars in production; server refuses to boot on default/weak secret.
JWT_SECRET="replace-with-strong-32-char-min-secret"
JWT_ISSUER=plink
# Comma-separated allowlist of audiences accepted on access tokens.
# Allows safe rollout across iOS / Android / desktop without re-issuing tokens.
JWT_AUDIENCES=plink-ios,plink-android,plink-desktop

# CORS — allowlist, never "*" with credentials
CORS_ORIGIN="https://app.plink.example,https://staging.plink.example"

# Feature flags — see §15 rollout plan
APP_STORE_COMPLIANT=true
ENABLE_LEGACY_STREAM_RELAY=false
REALTIME_PROTOCOL_V2=true
NATIVE_PLAYER_V2=true
LIVEKIT_SFU=false
WATCH_SCREEN_V2=false

# LiveKit (Stage 9)
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Observability
SENTRY_DSN=""
OTEL_ENDPOINT=""

# Media (signed URL TTL in seconds; 60-300)
SIGNED_MEDIA_URL_TTL=120
