// prisma/schema.prisma — Pack 5: с Referral, FeatureFlag, AdBreak моделями
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  FOUNDER
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  password     String
  avatarURL    String?
  /// 🔧 v11 (July 2026): Telegram-style display name (separate from @username).
  /// nil = use username as display name (backward compat).
  displayName  String?
  /// 🔧 v11: profile cover photo URL — banner shown on profile screen.
  coverURL     String?
  isOnline     Boolean  @default(false)
  isPremium    Boolean  @default(false)
  premiumUntil DateTime?
  role         UserRole @default(USER)
  bannedUntil  DateTime?
  fcmToken     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  twofaSecret      String?
  twofaEnabled     Boolean  @default(false)
  twofaBackupCodes String?

  referralCode String?

  hostedRooms      Room[]            @relation("HostRooms")
  participations   RoomParticipant[]
  sentMessages     ChatMessage[]
  sentDMs          DirectMessage[]   @relation("SentDMs")
  receivedDMs      DirectMessage[]   @relation("ReceivedDMs")
  friendRequestsSent     FriendRequest[]  @relation("RequestsSent")
  friendRequestsReceived FriendRequest[]  @relation("RequestsReceived")
  friendshipsInitiated   Friendship[]     @relation("FriendshipsInitiated")
  friendshipsReceived    Friendship[]     @relation("FriendshipsReceived")
  watchHistory     WatchHistory[]
  playbackStates   PlaybackState[]
  subscriptions    Subscription[]
  blockedUsers     UserBlock[]       @relation("Blocker")
  blockedBy        UserBlock[]       @relation("Blocked")
  reports          Report[]          @relation("Reporter")
  reportsResolved  Report[]          @relation("Resolver")
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  referralsMade    Referral[] @relation("Referrer")
  referralReceived Referral?  @relation("Referred")
  // PATCH 16: App Store Server API V2 transaction records
  transactions     TransactionRecord[]
}

model Room {
  id             String   @id @default(uuid())
  name           String
  hostID         String
  host           User     @relation("HostRooms", fields: [hostID], references: [id])
  hostName       String
  code           String   @unique
  mediaItem      String?
  isActive       Boolean  @default(true)
  maxParticipants Int     @default(10)
  hostIsPremium  Boolean  @default(false)
  createdAt      DateTime @default(now())
  privacy        String   @default("public")
  password       String?

  participants   RoomParticipant[]
  messages       ChatMessage[]
  playbackStates PlaybackState[]
  watchHistory   WatchHistory[]
  reports        Report[]          @relation("ReportedRoom")
  adBreaks       AdBreak[]
}

model RoomParticipant {
  id       String   @id @default(uuid())
  roomID   String
  room     Room     @relation(fields: [roomID], references: [id], onDelete: Cascade)
  userID   String
  user     User     @relation(fields: [userID], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([roomID, userID])
  @@index([userID, joinedAt])
}

model ChatMessage {
  id        String   @id @default(uuid())
  roomID    String
  room      Room     @relation(fields: [roomID], references: [id], onDelete: Cascade)
  senderID  String
  sender    User     @relation(fields: [senderID], references: [id])
  text      String
  createdAt DateTime @default(now())

  @@index([roomID, createdAt])
}

model DirectMessage {
  id          String   @id @default(uuid())
  senderID    String
  sender      User     @relation("SentDMs", fields: [senderID], references: [id])
  receiverID  String
  receiver    User     @relation("ReceivedDMs", fields: [receiverID], references: [id])
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([senderID, receiverID])
}

model FriendRequest {
  id         String   @id @default(uuid())
  fromUserID String
  fromUser   User     @relation("RequestsSent", fields: [fromUserID], references: [id])
  toUserID   String
  toUser     User     @relation("RequestsReceived", fields: [toUserID], references: [id])
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@unique([fromUserID, toUserID])
}

model Friendship {
  id           String   @id @default(uuid())
  userID       String
  user         User     @relation("FriendshipsInitiated", fields: [userID], references: [id])
  friendID     String
  friend       User     @relation("FriendshipsReceived", fields: [friendID], references: [id])
  friendsSince DateTime @default(now())

  @@unique([userID, friendID])
}

model WatchHistory {
  id        String   @id @default(uuid())
  userID    String
  user      User     @relation(fields: [userID], references: [id])
  roomID    String?
  room      Room?    @relation(fields: [roomID], references: [id])
  mediaTitle String?
  watchedAt DateTime @default(now())
}

model PlaybackState {
  id         String   @id @default(uuid())
  roomID     String
  room       Room     @relation(fields: [roomID], references: [id], onDelete: Cascade)
  userID     String?
  user       User?    @relation(fields: [userID], references: [id])
  currentTime    Float    @default(0)
  isPlaying   Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  // P1-39: removed @@unique([roomID, userID]) from schema — migration uses
  // partial unique indexes instead (WHERE userID IS NOT NULL / IS NULL).
  // Prisma migrate diff now produces empty diff against fresh DB.
  @@index([roomID, updatedAt])
}

model Subscription {
  id                    String   @id @default(uuid())
  userID                String
  user                  User     @relation(fields: [userID], references: [id])
  plan                  String   @default("monthly")
  isActive              Boolean  @default(true)
  expiresAt             DateTime
  createdAt             DateTime @default(now())
  // PATCH 16: App Store Server API V2 fields
  originalTransactionId String?  // stable across renewals
  environment           String?  // "Sandbox" | "Production"
  revokedAt             DateTime?
  lastVerifiedAt        DateTime?
  @@index([userID, isActive])
  @@index([originalTransactionId])
}

/// PATCH 16: Signed transaction records (JWS) from App Store Server API V2.
/// One row per verified transaction. Used for audit trail + revocation.
model TransactionRecord {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  transactionId         String   @unique  // stable per transaction
  originalTransactionId String
  productId             String
  environment           String   // "Sandbox" | "Production"
  jws                   String   @db.Text  // signed JWS from Apple
  expiresAt             DateTime?
  revocationDate        DateTime?
  verifiedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  @@index([userId, createdAt])
  @@index([originalTransactionId])
  @@index([productId])
}

model UserBlock {
  id          String @id @default(uuid())
  blockerID   String
  blocker     User   @relation("Blocker", fields: [blockerID], references: [id])
  blockedID   String
  blocked     User   @relation("Blocked", fields: [blockedID], references: [id])
  createdAt   DateTime @default(now())

  @@unique([blockerID, blockedID])
}

model Report {
  id          String   @id @default(uuid())
  reporterID  String
  reporter    User     @relation("Reporter", fields: [reporterID], references: [id])
  roomID      String?
  reportedRoom Room?   @relation("ReportedRoom", fields: [roomID], references: [id])
  reason      String
  status      String   @default("pending")  // pending | resolved | dismissed
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  resolver    User?    @relation("Resolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// Pack 5: НОВЫЕ МОДЕЛИ

model Referral {
  id          String   @id @default(uuid())
  referrerId  String
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId  String   @unique
  referred    User     @relation("Referred", fields: [referredId], references: [id])
  status      String   @default("completed")
  rewardDays  Int      @default(7)
  createdAt   DateTime @default(now())

  @@index([referrerId])
}

model FeatureFlag {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AdBreak {
  id          String   @id @default(uuid())
  roomID      String
  room        Room     @relation(fields: [roomID], references: [id], onDelete: Cascade)
  startTime   Float
  endTime     Float
  adType      String   @default("preroll")
  createdAt   DateTime @default(now())

  @@index([roomID])
}
